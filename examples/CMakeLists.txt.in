# Top-level CMakeLists.txt for AOCL-DLP Examples
# This file allows building all example subdirectories

cmake_minimum_required(VERSION @CMAKE_MINIMUM_REQUIRED_VERSION@)

project(AOCL_DLP_Examples VERSION @PROJECT_VERSION@ LANGUAGES C CXX)

# Option to choose between static and shared library (propagated to subdirectories)
option(USE_STATIC_LIBRARY "Link with static AOCL-DLP library" OFF)

# Find the installed AOCL-DLP package (required by all subdirectories)
find_package(AoclDlp REQUIRED)

# Find OpenMP (required by examples)
find_package(OpenMP REQUIRED COMPONENTS C CXX)

# Add subdirectories
add_subdirectory(classic)
