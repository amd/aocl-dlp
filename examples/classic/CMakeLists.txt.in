# Standalone CMakeLists.txt for AOCL-DLP Classic Examples
# This file is designed to work with an installed AOCL-DLP library
# Can be used standalone or as a subdirectory

# Only set project and find dependencies if this is the top-level project
if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR)
    cmake_minimum_required(VERSION @CMAKE_MINIMUM_REQUIRED_VERSION@)
    project(AOCL_DLP_Classic_Examples VERSION @PROJECT_VERSION@ LANGUAGES C CXX)

    # Option to choose between static and shared library
    option(USE_STATIC_LIBRARY "Link with static AOCL-DLP library" OFF)

    # Find the installed AOCL-DLP package
    find_package(AoclDlp REQUIRED)

    # Find OpenMP (required by examples)
    find_package(OpenMP REQUIRED COMPONENTS C CXX)
endif()

# Set source directory
set(EXAMPLE_SOURCE_DIR "${CMAKE_CURRENT_SOURCE_DIR}/src")

# List of example source files
set(EXAMPLE_SOURCES
    simple_gemm_f32.c
    multi_instance_gemm_f32.c
    multi_instance_gemm_u8s8.c
    simple_gemm_bf16.c
    simple_gemm_s8.c
    simple_gemm_with_bias.c
    simple_gemm_with_relu.c
    matrix_reorder.c
    batch_gemm.c
    quantization.c
    simple_gemm_s8_sym_quant.c
    post_ops_combinations.c
    eltwise_ops.c
    version.c
)

# Choose library target based on user preference
if(USE_STATIC_LIBRARY)
    set(AOCL_DLP_TARGET AoclDlp::aocl-dlp_static)
    message(STATUS "Using static AOCL-DLP library")
else()
    set(AOCL_DLP_TARGET AoclDlp::aocl-dlp)
    message(STATUS "Using shared AOCL-DLP library")
endif()

# Create an executable for each example source file
foreach(source ${EXAMPLE_SOURCES})
    # Extract the filename without extension
    get_filename_component(example_name ${source} NAME_WE)

    # Add executable with source from src directory
    add_executable(${example_name} ${EXAMPLE_SOURCE_DIR}/${source})

    # Link with AOCL-DLP library (includes all necessary include directories)
    target_link_libraries(${example_name}
        PRIVATE
            ${AOCL_DLP_TARGET}
    )

    # Link with OpenMP
    if(OpenMP_C_FOUND)
        target_link_libraries(${example_name} PRIVATE OpenMP::OpenMP_C)
    endif()
    if(OpenMP_CXX_FOUND)
        target_link_libraries(${example_name} PRIVATE OpenMP::OpenMP_CXX)
    endif()
    if(OpenMP_C_FOUND OR OpenMP_CXX_FOUND)
        target_compile_definitions(${example_name} PRIVATE DLP_EXAMPLE_ENABLE_OPENMP)
    endif()

    # Link with math library on Unix/Linux
    if(UNIX)
        target_link_libraries(${example_name} PRIVATE m)
    endif()

    message(STATUS "Added example: ${example_name}")
endforeach()

# Print build information
message(STATUS "")
message(STATUS "==========================================")
message(STATUS "AOCL-DLP Examples Configuration Summary")
message(STATUS "==========================================")
message(STATUS "AOCL-DLP Version: ${AoclDlp_VERSION}")
message(STATUS "Library Type: ${AOCL_DLP_TARGET}")
message(STATUS "Build Type: ${CMAKE_BUILD_TYPE}")
message(STATUS "C Compiler: ${CMAKE_C_COMPILER}")
message(STATUS "CXX Compiler: ${CMAKE_CXX_COMPILER}")
message(STATUS "==========================================")
message(STATUS "")
