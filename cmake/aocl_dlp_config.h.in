#ifndef AOCL_DLP_CONFIG_H
#define AOCL_DLP_CONFIG_H

// Version information
#define AOCL_DLP_VERSION_MAJOR "@PROJECT_VERSION_MAJOR@"
#define AOCL_DLP_VERSION_MINOR "@PROJECT_VERSION_MINOR@"
#define AOCL_DLP_VERSION_PATCH "@PROJECT_VERSION_PATCH@"

#define AOCL_DLP_VERSION       "@PROJECT_VERSION@"

// Build configuration
#cmakedefine DLP_ENABLE_OPENMP
#cmakedefine DLP_ENABLE_PTHREAD

// Operating System
#cmakedefine01 DLP_OS_UNIX
#cmakedefine01 DLP_OS_LINUX
#cmakedefine01 DLP_OS_MACOS
#cmakedefine01 DLP_OS_WINDOWS

#if DLP_OS_LINUX
#define DLP_LINUX_DISTRIBUTION         "@DLP_LINUX_DISTRIBUTION@"
#define DLP_LINUX_DISTRIBUTION_VERSION "@DLP_LINUX_DISTRIBUTION_VERSION@"
#endif

#if DLP_OS_WINDOWS
#define DLP_WINDOWS_VERSION "@DLP_WINDOWS_VERSION@"
#define DLP_WINDOWS_NAME    "@DLP_WINDOWS_NAME@"
#endif

// Compiler information
#cmakedefine01 DLP_COMPILER_GCC
#cmakedefine01 DLP_COMPILER_CLANG
#cmakedefine01 DLP_COMPILER_INTEL
#cmakedefine01 DLP_COMPILER_MSVC

#define DLP_COMPILER_NAME    "@DLP_COMPILER_NAME@"
#define DLP_COMPILER_VERSION "@DLP_COMPILER_VERSION@"

#if DLP_COMPILER_MSVC
#define DLP_COMPILER_MSVC_YEAR "@DLP_COMPILER_MSVC_YEAR@"
#endif

// Endianness
#cmakedefine01 DLP_IS_BIG_ENDIAN
#define DLP_ENDIAN "@DLP_ENDIAN@"

// Testing Config
#cmakedefine01 DLP_TESTING_ENABLE_HIGH_PRECISION_FLOAT
#cmakedefine01 DLP_TESTING_ENABLE_DETAILED_DEBUG

// Legacy support (deprecated)
#cmakedefine01 DLP_ENABLE_HIGH_PRECISION_FLOAT
#cmakedefine01 DLP_ENABLE_DETAILED_DEBUG

#endif // AOCL_DLP_CONFIG_H
